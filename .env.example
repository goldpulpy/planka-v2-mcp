# ================================================================================
# Planka Configuration
# ================================================================================

# --- Planka URL ------------------------------------------------------------------
PLANKA_BASE_URL=https://planka.example.com

# --- Agent (LLM) Credentials -----------------------------------------------------
PLANKA_AGENT_EMAIL=agent@example.com
PLANKA_AGENT_PASSWORD=your_password_here

# --- Admin (optional, for specific operations) ------------------------------------
# You may optionally specify either Email or ID (not required, choose one if needed)
PLANKA_ADMIN_EMAIL=admin@example.com
# PLANKA_ADMIN_ID=0000000000000000000

# --- Connection Settings ----------------------------------------------------------
PLANKA_IGNORE_SSL=true