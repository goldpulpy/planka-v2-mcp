{
  "name": "@goldpulpy/planka-v2-mcp",
  "version": "1.0.1",
  "description": "MCP server for Planka v2.x Kanban board",
  "license": "MIT",
  "author": "goldpulpy <sawsani1928@gmail.com>",
  "homepage": "https://github.com/goldpulpy/planka-v2-mcp",
  "bugs": "https://github.com/goldpulpy/planka-v2-mcp/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/goldpulpy/planka-v2-mcp.git"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "planka-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "watch": "tsc --watch",
    "inspector": "cross-env SERVER_PORT=3008 CLIENT_PORT=5174 DOTENV_CONFIG_PATH=.env npx -y @modelcontextprotocol/inspector node -r dotenv/config dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests --testPathIgnorePatterns=tests/integration.test.ts",
    "test:coverage": "npm test -- --coverage",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/integration.test.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "qc": "npm run typecheck && npm run lint && npm run build && npm run test",
    "planka:up": "docker compose -f dev/docker-compose.yml up -d",
    "planka:down": "docker compose -f dev/docker-compose.yml down",
    "planka:clear": "docker compose -f dev/docker-compose.yml down --volumes --remove-orphans",
    "clear": "shx rm -rf dist node_modules",
    "prepublishOnly": "npm run qc"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "node-fetch": "^3.3.2",
    "universal-user-agent": "^7.0.2",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "jest": "^29.7.0",
    "shx": "^0.3.4",
    "ts-jest": "^29.2.6",
    "typescript": "^5.6.2"
  }
}
