{
  "name": "@navyatec/planka-v2-mcp",
  "version": "1.3.5",
  "description": "MCP server for Planka v2.x Kanban board",
  "license": "MIT",
  "author": "NAVYA TECNOLOGÍA 2024, S.L. (original by Brad Risse)",
  "homepage": "https://github.com/Navya-Tecnologia/planka-v2-mcp",
  "bugs": "https://github.com/Navya-Tecnologia/planka-v2-mcp/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/Navya-Tecnologia/planka-v2-mcp.git"
  },
  "type": "module",
  "bin": {
    "planka-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "watch": "tsc --watch",
    "up": "docker compose --env-file .env up -d",
    "down": "docker compose down",
    "restart": "docker compose --env-file .env restart",
    "build-docker": "npm run build && docker build -t mcp-kanban:latest .",
    "start-node": "node dist/index.js",
    "inspector": "SERVER_PORT=3008 CLIENT_PORT=5174 npx -y @modelcontextprotocol/inspector node dist/index.js",
    "inspector:demo": "SERVER_PORT=3008 CLIENT_PORT=5174 npx -y @modelcontextprotocol/inspector node dist/index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testMatch='**/tests/**/*.test.ts'",
    "qc": "npm run build && npm test",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^22",
    "@types/node-fetch": "^2.6.12",
    "node-fetch": "^3.3.2",
    "universal-user-agent": "^7.0.2",
    "zod": "^3.22.4",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "shx": "^0.3.4",
    "ts-jest": "^29.2.6",
    "typescript": "^5.6.2"
  }
}
